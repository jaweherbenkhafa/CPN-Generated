      <block id="ID1412310166">
        <id>Standard priorities</id>
        <ml id="ID1412310255">val P_HIGH = 100;
          <layout>val P_HIGH = 100;</layout>
        </ml>
        <ml id="ID1412310292">val P_NORMAL = 1000;
          <layout>val P_NORMAL = 1000;</layout>
        </ml>
        <ml id="ID1412310322">val P_LOW = 10000;
          <layout>val P_LOW = 10000;</layout>
        </ml>
      </block>
      <block id="ID1">
        <id>Standard declarations</id>
        <color id="ID1426096113">
          <id>AIRCRAFTS</id>
          <enum>
            <id>A1</id>
            <id>A2</id>
            <id>A3</id>
            <id>A4</id>
            <id>A5</id>
          </enum>
          <layout>colset AIRCRAFTS = with A1 | A2 | A3 | A4 | A5;</layout>
        </color>
        <color id="ID1426099680">
          <id>STATUS</id>
          <enum>
            <id>Blocked</id>
            <id>ReadyL</id>
            <id>Landing</id>
            <id>TerminatedL</id>
            <id>ReadyT</id>
            <id>TakingOff</id>
          </enum>
          <layout>colset STATUS = with Blocked | ReadyL | Landing | TerminatedL | ReadyT | TakingOff;</layout>
        </color>
        <var id="ID1427877973">
          <type>
            <id>STATUS</id>
          </type>
          <id>blocked</id>
          <id>readyL</id>
          <id>landing</id>
          <id>terminatedL</id>
          <id>readyT</id>
          <id>takingoff</id>
          <layout>var blocked,readyL,landing,terminatedL,readyT,takingoff:STATUS;</layout>
        </var>
        <var id="ID1426113568">
          <type>
            <id>AIRCRAFTS</id>
          </type>
          <id>aircraft</id>
          <layout>var aircraft:AIRCRAFTS;</layout>
        </var>
        <color id="ID1426118118">
          <id>AIRCRAFT_STATUS</id>
          <product>
            <id>AIRCRAFTS</id>
            <id>STATUS</id>
          </product>
          <layout>colset AIRCRAFT_STATUS = product AIRCRAFTS * STATUS;</layout>
        </color>
        <color id="ID1426573447">
          <id>RW_STATUES</id>
          <enum>
            <id>Available</id>
            <id>Unavailable</id>
          </enum>
          <layout>colset RW_STATUES = with Available | Unavailable;</layout>
        </color>
        <var id="ID1427573256">
          <type>
            <id>RW_STATUES</id>
          </type>
          <id>unavailable</id>
          <id>available</id>
          <layout>var unavailable,  available :  RW_STATUES;</layout>
        </var>
        <color id="ID1426586216">
          <id>RWL_STATUES</id>
          <enum>
            <id>OFF</id>
            <id>ON</id>
          </enum>
          <layout>colset RWL_STATUES = with OFF | ON;</layout>
        </color>
        <var id="ID1427711579">
          <type>
            <id>RWL_STATUES</id>
          </type>
          <id>on</id>
          <id>off</id>
          <layout>var on ,off: RWL_STATUES;</layout>
        </var>
        <color id="ID1426972504">
          <id>Hours</id>
          <int>
            <with>
              <ml>0</ml>
              <ml>23</ml>
            </with>
          </int>
          <layout>colset Hours = int with 0..23;</layout>
        </color>
        <color id="ID1426972806">
          <id>Minute</id>
          <int>
            <with>
              <ml>0</ml>
              <ml>59</ml>
            </with>
          </int>
          <layout>colset Minute= int with 0..59;</layout>
        </color>
        <color id="ID1426973160">
          <id>ready_to_takeoff_aircrafts</id>
          <alias>
            <id>AIRCRAFTS</id>
          </alias>
          <layout>colset ready_to_takeoff_aircrafts=AIRCRAFTS;</layout>
        </color>
        <color id="ID1426972978">
          <id>DepH</id>
          <product>
            <id>ready_to_takeoff_aircrafts</id>
            <id>Hours</id>
          </product>
          <layout>colset DepH=  product ready_to_takeoff_aircrafts* Hours;</layout>
        </color>
        <color id="ID1426973561">
          <id>DepM</id>
          <product>
            <id>ready_to_takeoff_aircrafts</id>
            <id>Minute</id>
          </product>
          <layout>colset DepM=  product ready_to_takeoff_aircrafts* Minute;</layout>
        </color>
        <var id="ID1426976661">
          <type>
            <id>Minute</id>
          </type>
          <id>arrm</id>
          <id>Curtm</id>
          <id>arrmx</id>
          <id>decom</id>
          <layout>var arrm,Curtm,arrmx,decom: Minute;</layout>
        </var>
        <color id="ID1426993183">
          <id>TakeoffDeadline</id>
          <product>
            <id>ready_to_takeoff_aircrafts</id>
            <id>Hours</id>
            <id>Minute</id>
          </product>
          <layout>colset TakeoffDeadline= product ready_to_takeoff_aircrafts * Hours* Minute;</layout>
        </color>
        <var id="ID1426981390">
          <type>
            <id>Hours</id>
          </type>
          <id>arrh</id>
          <layout>var arrh: Hours;</layout>
        </var>
        <color id="ID1427018519">
          <id>ready_to_landing_aircrafts</id>
          <alias>
            <id>AIRCRAFTS</id>
          </alias>
          <layout>colset ready_to_landing_aircrafts=AIRCRAFTS;</layout>
        </color>
        <color id="ID1427020615">
          <id>ArrivalM</id>
          <product>
            <id>ready_to_landing_aircrafts</id>
            <id>Minute</id>
          </product>
          <layout>colset ArrivalM=  product ready_to_landing_aircrafts* Minute;</layout>
        </color>
        <color id="ID1427022208">
          <id>ArrivalH</id>
          <product>
            <id>ready_to_landing_aircrafts</id>
            <id>Hours</id>
          </product>
          <layout>colset ArrivalH=  product ready_to_landing_aircrafts* Hours;</layout>
        </color>
        <color id="ID1427023287">
          <id>LandingDeadline</id>
          <product>
            <id>ready_to_landing_aircrafts</id>
            <id>Hours</id>
            <id>Minute</id>
          </product>
          <layout>colset LandingDeadline= product ready_to_landing_aircrafts * Hours* Minute;</layout>
        </color>
        <color id="ID85042">
          <id>UNIT</id>
          <unit/>
          <layout>colset UNIT = unit;</layout>
        </color>
        <color id="ID4">
